# Copy this file to .env and fill in your own keys.
# Groq — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# USDA FoodData Central (free) — https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your_usda_api_key_here

# SMS Reminders via Twilio — https://www.twilio.com/try-twilio (free trial)
# Account SID + Auth Token are on the Twilio Console dashboard.
# TWILIO_FROM is your Twilio (trial) phone number in E.164 format, e.g. +12025550123.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1XXXXXXXXXX
# Shared secret the scheduled GitHub Action passes to /api/reminders/run
REMINDER_CRON_TOKEN=generate_a_long_random_string

# FREE SMS delivery via carrier email-to-SMS gateway (preferred over Twilio).
# Uses Gmail SMTP to email the carrier gateway (e.g. 5108767182@tmomail.net),
# which the carrier turns into a text. GMAIL_APP_PASSWORD is a 16-char Google
# "App Password" (Account → Security → 2-Step Verification → App passwords),
# NOT your normal Gmail password.
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmnop
